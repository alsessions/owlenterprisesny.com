{% extends "layout/_base.twig" %}

{% block title %}{{ currentSite.name }} - {{ entry.title }}{% endblock %}

{% block body %}
    {% set siteImage = entry.siteImage.one() %}

<section class="relative flex min-h-80 overflow-hidden bg-slate-900 sm:min-h-[28rem]">
    <div class="relative mx-auto flex w-full max-w-6xl items-end px-6 py-12 lg:px-8">
        <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
            <a href="{{ entry.url }}" class="transition hover:text-sky-100">{{ entry.title }}</a>
        </h1>
    </div>
</section>

<main class="mx-auto min-h-screen w-full max-w-6xl px-6 py-12 sm:py-16 lg:px-8">
    <section class="grid gap-10 md:grid-cols-2 md:items-start">
        <div>
            {% if entry.content %}
                <div class="prose prose-slate max-w-none">
                    {{ entry.content }}
                </div>
            {% endif %}

            {% if entry.resourceLink %}
                <a href="{{ entry.resourceLink }}" class="mt-6 inline-flex items-center rounded-md bg-sky-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-sky-800" target="_blank" rel="noopener noreferrer">Visit Website</a>
            {% endif %}
        </div>

        {% if siteImage %}
            <div class="overflow-hidden rounded-lg bg-slate-200 shadow-sm">
                <img
                    class="h-auto w-full"
                    src="{{ siteImage.url }}"
                    alt="{{ siteImage.alt ?: entry.title }}"
                    loading="lazy"
                    decoding="async"
                >
            </div>
        {% endif %}
    </section>
</main>
{% endblock %}
