{% extends "layout/_base.twig" %}

{% block title %}{{ currentSite.name }} - Coming Soon{% endblock %}

{% block body %}
<div class="flex min-h-screen items-center justify-center p-6">
    <div class="grid w-full max-w-4xl overflow-hidden rounded-lg bg-white shadow-2xl md:grid-cols-2">
        <div class="p-8 md:p-10">
            <h1 class="text-4xl font-bold tracking-tight text-slate-950">Coming Soon</h1>
            <p class="mt-4 text-lg leading-8 text-slate-600">We'll be right with you.</p>
            <p class="mt-5 leading-7">Let's be real. This is mostly AI gibberish. Nobody wants that but it's a useful tool to flesh things out a bit.</p>
            <p class="mt-5 leading-7">We're building this thing in public and that's the way it goes.</p>
            <p class="mt-6">
                <a class="inline-flex items-center rounded-md bg-sky-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-sky-800" href="mailto:fultonchain@gmail.com">
                    Get in touch
                    <span class="ml-2" aria-hidden="true">&rarr;</span>
                </a>
            </p>
        </div>
        <div class="bg-slate-50 p-8 md:p-10">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Explore</h2>
            <ul class="mt-5 space-y-4">
                <li><a href="/web" class="font-medium text-sky-700 transition hover:text-sky-800">Web</a><br><small class="text-slate-500">Website strategy, builds, and featured web projects.</small></li>
                <li><a href="/print" class="font-medium text-sky-700 transition hover:text-sky-800">Print</a><br><small class="text-slate-500">Print design and production work for polished offline materials.</small></li>
                <li><a href="/marketing" class="font-medium text-sky-700 transition hover:text-sky-800">Marketing</a><br><small class="text-slate-500">Campaign support, messaging, and creative direction.</small></li>
            </ul>
        </div>
    </div>
</div>
{% endblock %}
