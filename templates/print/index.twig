{% extends "layout/_base.twig" %}

{% block title %}
    {%- set page = craft.entries().section('print').type('pageBuilder').one() -%}
    {{- currentSite.name }} - {{ page ? page.title : 'Print' -}}
{% endblock %}

{% block body %}
    {% set page = craft.entries()
        .section('print')
        .type('pageBuilder')
        .one() %}
    {% set heroImage = page ? page.heroImage.one() : null %}
    {% set printItems = craft.entries()
        .section('printItem')
        .type('website')
        .all() %}

{% if page %}
    <section class="relative flex min-h-80 overflow-hidden bg-slate-900 sm:min-h-[28rem]">
        {% if heroImage %}
            <img
                class="absolute inset-0 h-full w-full object-cover object-center"
                src="{{ heroImage.url }}"
                alt="{{ heroImage.alt ?: page.title }}"
            >
            <div class="absolute inset-0 bg-slate-950/55"></div>
        {% endif %}

        <div class="relative mx-auto flex w-full max-w-5xl items-end px-6 py-12 lg:px-8">
            <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">{{ page.title }}</h1>
        </div>
    </section>
{% endif %}

<main class="mx-auto min-h-screen w-full max-w-5xl px-6 py-12 sm:py-16 lg:px-8">
    <section>
        {% if page %}
            {% if page.content %}
                <div class="prose prose-slate max-w-none">
                    {{ page.content }}
                </div>
            {% endif %}
        {% else %}
            <div class="text-center">
                <h1 class="text-3xl font-bold tracking-tight text-slate-950">Print</h1>
                <p class="mt-4 text-slate-600">Content is coming soon.</p>
            </div>
        {% endif %}

        {% if printItems %}
            <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {% for printItem in printItems %}
                    {% set siteImage = printItem.siteImage.one() %}

                    <article class="overflow-hidden rounded-lg bg-white shadow-sm">
                        {% if siteImage %}
                            <a href="{{ printItem.url }}" class="block aspect-video overflow-hidden bg-slate-200">
                                <img
                                    class="h-full w-full object-cover object-center transition duration-300 hover:scale-105"
                                    src="{{ siteImage.url }}"
                                    alt="{{ siteImage.alt ?: printItem.title }}"
                                    loading="lazy"
                                    decoding="async"
                                >
                            </a>
                        {% endif %}

                        <div class="p-5">
                            <h2 class="text-xl font-bold tracking-tight text-slate-950">
                                <a href="{{ printItem.url }}" class="transition hover:text-sky-700">{{ printItem.title }}</a>
                            </h2>

                            {% if printItem.content %}
                                <div class="prose prose-slate mt-4 line-clamp-4">
                                    {{ printItem.content }}
                                </div>
                            {% endif %}
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </section>
</main>
{% endblock %}
