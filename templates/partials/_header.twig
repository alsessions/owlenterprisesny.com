<header class="border-b border-slate-200 bg-white">
    <input id="site-nav-toggle" type="checkbox" class="peer sr-only">

    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 lg:px-8" aria-label="Main navigation">
        <a href="/" class="site-title text-lg font-bold tracking-tight">
            {{ currentSite.name }}
        </a>

        <label for="site-nav-toggle" class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-md text-slate-700 ring-1 ring-slate-200 md:hidden" aria-label="Toggle navigation">
            <span class="space-y-1.5">
                <span class="block h-0.5 w-5 bg-current"></span>
                <span class="block h-0.5 w-5 bg-current"></span>
                <span class="block h-0.5 w-5 bg-current"></span>
            </span>
        </label>

        <div class="hidden items-center gap-8 text-sm font-medium text-slate-700 md:flex">
            <a href="/web" class="transition hover:text-sky-700">Web</a>
            <a href="/print" class="transition hover:text-sky-700">Print</a>
            <a href="/marketing" class="transition hover:text-sky-700">Marketing</a>
        </div>
    </nav>

    <div class="hidden border-t border-slate-200 px-6 pb-4 peer-checked:block md:hidden">
        <div class="mx-auto flex max-w-6xl flex-col gap-3 pt-4 text-sm font-medium text-slate-700">
            <a href="/web" class="transition hover:text-sky-700">Web</a>
            <a href="/print" class="transition hover:text-sky-700">Print</a>
            <a href="/marketing" class="transition hover:text-sky-700">Marketing</a>
        </div>
    </div>
</header>
